{
  "experience_formulas": {
    "sales": {
      "base": 10,
      "multiplier": 1.0,
      "formula": "sales_count * base * multiplier",
      "description": "판매 건수에 비례"
    },
    "marketing": {
      "base": 0.5,
      "multiplier": 1.0,
      "formula": "achievement_rate * base * multiplier",
      "description": "목표 달성률에 비례"
    },
    "pricing": {
      "base": 0.001,
      "multiplier": 1.0,
      "formula": "total_revenue * base * multiplier",
      "description": "총 수익에 비례"
    },
    "financial": {
      "base": 0.1,
      "multiplier": 1.0,
      "formula": "roi * base * multiplier",
      "description": "ROI에 비례"
    },
    "agriculture": {
      "base": 5,
      "multiplier": 1.0,
      "formula": "harvest_kg * base * multiplier",
      "description": "수확량에 비례"
    },
    "distribution": {
      "base": 8,
      "multiplier": 1.0,
      "formula": "delivery_count * base * multiplier",
      "description": "배송 건수에 비례"
    }
  },
  "level_requirements": {
    "1": 0,
    "2": 100,
    "3": 500,
    "4": 2000,
    "5": 5000
  },
  "rarity_mapping": {
    "1": "common",
    "2": "uncommon",
    "3": "rare",
    "4": "epic",
    "5": "legendary"
  },
  "nft_config": {
    "min_level_to_mint": 3,
    "base_price_per_level": 5000,
    "royalty_rate": 0.1,
    "buyer_experience_rate": 0.8,
    "remaining_learning_required": 0.2
  },
  "skill_transfer_config": {
    "agriculture->distribution": {
      "source": "agriculture",
      "target": "distribution",
      "retention_rate": 0.7,
      "adaptation_period_days": 7,
      "daily_adaptation_exp": 50,
      "mapping": {
        "재배_일정_관리": "유통_일정_관리",
        "수확량_예측": "수요_예측",
        "병해충_진단": "문제_상품_식별"
      }
    },
    "marketing->sales": {
      "source": "marketing",
      "target": "sales",
      "retention_rate": 0.8,
      "adaptation_period_days": 5,
      "daily_adaptation_exp": 60,
      "mapping": {
        "타겟_고객_분석": "영업_대상_선정",
        "메시지_최적화": "세일즈_피치",
        "캠페인_자동화": "영업_프로세스_자동화"
      }
    },
    "finance->investment": {
      "source": "finance",
      "target": "investment",
      "retention_rate": 0.9,
      "adaptation_period_days": 3,
      "daily_adaptation_exp": 70,
      "mapping": {
        "현금_흐름_최적화": "투자_포트폴리오_관리",
        "리스크_관리": "투자_리스크_분석",
        "예산_수립": "투자_계획_수립"
      }
    }
  },
  "collaboration_config": {
    "share_experience": {
      "experience_share_rate": 0.8,
      "min_participants": 2,
      "max_participants": 10
    },
    "competitive": {
      "winner_multiplier": 2.0,
      "top_10_percent_multiplier": 1.5,
      "participant_multiplier": 1.2
    },
    "mentor_mentee": {
      "mentee_multiplier": 1.2,
      "mentor_multiplier": 0.5,
      "mentor_reputation_bonus": 100
    }
  },
  "challenge_config": {
    "experience_multipliers": {
      "top_10_percent": 2.0,
      "top_25_percent": 1.5,
      "participant": 1.2
    },
    "min_entry_fee": 1000,
    "max_entry_fee": 100000,
    "min_duration_days": 1,
    "max_duration_days": 30
  },
  "spirit_score_config": {
    "base_score": 0.5,
    "factors": {
      "investment_success_rate": {
        "weight": 0.3,
        "formula": "successful_investments / total_investments"
      },
      "nft_reliability": {
        "weight": 0.2,
        "formula": "(positive_reviews / total_reviews) if total_reviews > 0 else 0.5"
      },
      "collaboration_contribution": {
        "weight": 0.25,
        "formula": "total_collaboration_experience / 10000"
      },
      "sponsor_ratio": {
        "weight": 0.15,
        "formula": "sponsor_amount / total_revenue"
      },
      "community_activity": {
        "weight": 0.1,
        "formula": "(challenge_participations + mentoring_sessions) / 50"
      }
    },
    "penalties": {
      "investment_default": -0.1,
      "nft_fraud": -0.2,
      "collaboration_abandon": -0.05
    }
  },
  "time_warp_config": {
    "speed_multiplier": 100,
    "scenarios": {
      "balanced": {
        "sales_rate": 0.7,
        "price_variance": 0.1,
        "risk": 0.3
      },
      "aggressive": {
        "sales_rate": 0.5,
        "price_variance": 0.2,
        "risk": 0.5
      },
      "conservative": {
        "sales_rate": 0.85,
        "price_variance": 0.05,
        "risk": 0.1
      }
    }
  }
}